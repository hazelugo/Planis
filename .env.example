# Copy to .env.local and fill in your values
# Supabase: Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Canonical app URL for magic-link redirects (required in production)
# Also add this URL under Supabase → Authentication → URL Configuration:
#   Site URL: https://your-domain.com
#   Redirect URLs: https://your-domain.com/**
VITE_APP_URL=https://planis.hazelugo.com
# Pexels: https://www.pexels.com/api/
VITE_PEXELS_API_KEY=your-pexels-api-key-here
